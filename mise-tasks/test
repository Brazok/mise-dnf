#!/usr/bin/env bash
#MISE description="Run plugin tests - install an RPM package via dnf backend"
set -euo pipefail

mise settings experimental=true

mise plugin link --force dnf .
mise cache clear

# Install jq (small, self-contained binary) via the dnf backend
mise use dnf:jq@latest

# Verify the binary is usable
output=$(mise exec "dnf:jq" -- jq --version 2>&1)
echo "jq output: $output"

if echo "$output" | grep -q "jq-"; then
    echo "✓ Tests passed"
else
    echo "✗ Test failed: expected jq version output"
    exit 1
fi
