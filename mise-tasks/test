#!/usr/bin/env bash
#MISE description="Run plugin tests - install and execute tool"
set -euo pipefail

mise plugin link --force mise-dnf .
mise cache clear
mise install mise-dnf@1.0.0

# Capture and display the output while also verifying it
output=$(mise exec "mise-dnf@1.0.0" -- "mise-dnf" --version)
echo "mise-dnf output: $output"

if echo "$output" | grep -q 'mise-dnf@1.0.0'; then
    echo "✓ Tests passed"
else
    echo "✗ Test failed: expected version mise-dnf@1.0.0"
    exit 1
fi
